<routes>

    <vTypeDistribution id="mixed_traffic">
        <vType id="car" probability="0.7" guiShape="passenger" color="1,0,0"/>
        <vType id="bus" probability="0.2" guiShape="bus" color="0,0,1"/>
        <vType id="truck" probability="0.1" guiShape="truck" color="0,1,0"/>
    </vTypeDistribution>

    <!-- STRAIGHT ROUTES -->
    <route id="WE" edges="E3 E0.54"/>
    <route id="NS" edges="E1 E1.39"/>
    <route id="EW" edges="-E0 -E00"/>
    <route id="SN" edges="-E1 -E10"/>

    <!-- NEW RIGHT TURNS -->
    <route id="N_to_E" edges="E1 E0.54"/>
    <route id="S_to_W" edges="-E1 -E00"/>
    <route id="E_to_S" edges="E3 -E10"/>
    <route id="W_to_N" edges="-E0 E1.39"/>

    <!-- NEW LEFT TURNS -->
    <route id="N_to_W" edges="E1 -E00"/>
    <route id="S_to_E" edges="-E1 E0.54"/>
    <route id="E_to_N" edges="E3 E1.39"/>
    <route id="W_to_S" edges="-E0 -E10"/>

    <!-- FLOWS -->
    <flow id="f_NS" route="NS" type="mixed_traffic" begin="0" end="1000" probability="0.3"/>
    <flow id="f_SN" route="SN" type="mixed_traffic" begin="0" end="1000" probability="0.3"/>

    <flow id="f_WE" route="WE" type="mixed_traffic" begin="0" end="1000" probability="0.2"/>
    <flow id="f_EW" route="EW" type="mixed_traffic" begin="0" end="1000" probability="0.2"/>

    <!-- Turning flows -->
    <flow id="f_N_to_E" route="N_to_E" type="mixed_traffic" begin="0" end="1000" probability="0.1"/>
    <flow id="f_N_to_W" route="N_to_W" type="mixed_traffic" begin="0" end="1000" probability="0.1"/>

    <flow id="f_S_to_E" route="S_to_E" type="mixed_traffic" begin="0" end="1000" probability="0.1"/>
    <flow id="f_S_to_W" route="S_to_W" type="mixed_traffic" begin="0" end="1000" probability="0.1"/>

</routes>